{
  "all": true,
  "reporter": ["lcov", "text"],
  "include": [
    "packages/*/lib/**/*.{js,cjs,mjs,ts,cts,mts}",
    "codemods/*/lib/**/*.{js,cjs,mjs,ts,cts,mts}",
    "eslint/*/lib/**/*.{js,cjs,mjs,ts,cts,mts}"
  ],
  "exclude": [
    "packages/babel-standalone/**",
    "packages/babel-types/**/generated/*",
    "packages/babel-helpers/*/helpers/*"
  ]
}
